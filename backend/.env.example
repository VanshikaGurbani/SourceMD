# Anthropic API (REQUIRED)
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# Postgres
POSTGRES_USER=sourcemd
POSTGRES_PASSWORD=sourcemd_dev_password
POSTGRES_DB=sourcemd
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://sourcemd:sourcemd_dev_password@postgres:5432/sourcemd

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=guidelines

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# CORS
FRONTEND_ORIGIN=http://localhost:5173

# Tavily web search (OPTIONAL — augments ChromaDB with live results)
# Free tier: https://app.tavily.com (1000 searches/month, no credit card)
TAVILY_API_KEY=
